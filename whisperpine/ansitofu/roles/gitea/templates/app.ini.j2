APP_NAME = Gitea: Git with a cup of tea
RUN_USER = git
RUN_MODE = prod
WORK_PATH = /var/lib/gitea

[repository]
ROOT = /var/lib/gitea/git/repositories

[repository.local]
LOCAL_COPY_PATH = /tmp/gitea/local-repo

[repository.upload]
TEMP_PATH = /tmp/gitea/uploads

[server]
APP_DATA_PATH = /var/lib/gitea
SSH_DOMAIN = localhost
HTTP_PORT = 3000
ROOT_URL = "{{ gitea_root_url }}"
DISABLE_SSH = true
# In rootless gitea container only internal ssh server is supported.
START_SSH_SERVER = true
SSH_PORT = 2222
SSH_LISTEN_PORT = 2222
BUILTIN_SSH_SERVER_USER = git
LFS_START_SERVER = true
DOMAIN = localhost
LFS_JWT_SECRET = "{{ gitea_lfs_jwt_secret }}"
OFFLINE_MODE = true
LANDING_PAGE = "login"

[database]
PATH = /var/lib/gitea/data/gitea.db
DB_TYPE = sqlite3
HOST = localhost:3306
NAME = gitea
USER = root
PASSWD =
SCHEMA =
SSL_MODE = disable
LOG_SQL = false

[session]
PROVIDER_CONFIG = /var/lib/gitea/data/sessions
PROVIDER = file

[picture]
AVATAR_UPLOAD_PATH = /var/lib/gitea/data/avatars
REPOSITORY_AVATAR_UPLOAD_PATH = /var/lib/gitea/data/repo-avatars

[attachment]
PATH = /var/lib/gitea/data/attachments

[log]
ROOT_PATH = /var/lib/gitea/data/log
MODE = console
LEVEL = info

[security]
INSTALL_LOCK = true
SECRET_KEY =
REVERSE_PROXY_LIMIT = 1
REVERSE_PROXY_TRUSTED_PROXIES = *
INTERNAL_TOKEN = "{{ gitea_internal_token }}"
PASSWORD_HASH_ALGO = pbkdf2

[service]
DISABLE_REGISTRATION = false
REQUIRE_SIGNIN_VIEW = true
REGISTER_EMAIL_CONFIRM = true
ENABLE_NOTIFY_MAIL = false
ALLOW_ONLY_EXTERNAL_REGISTRATION = "{{ gitea_allow_only_external_registration }}"
ENABLE_CAPTCHA = false
DEFAULT_KEEP_EMAIL_PRIVATE = false
DEFAULT_ALLOW_CREATE_ORGANIZATION = false
DEFAULT_ENABLE_TIMETRACKING = true
NO_REPLY_ADDRESS = noreply.localhost
# Show the password login form or not.
ENABLE_PASSWORD_SIGNIN_FORM = "{{ gitea_enable_password_signin_form }}"

[lfs]
PATH = /var/lib/gitea/git/lfs

[mailer]
ENABLED = true
PROTOCOL = "smtps"
SMTP_ADDR = "{{ gitea_smtp_addr }}"
SMTP_PORT = "465"
FROM = "{{ gitea_email_from }}"
USER = "{{ gitea_smtp_user }}"
PASSWD = "{{ gitea_smtp_passwd }}"

[openid]
ENABLE_OPENID_SIGNIN = false
ENABLE_OPENID_SIGNUP = false

[cron.update_checker]
ENABLED = false

[repository.pull-request]
DEFAULT_MERGE_STYLE = merge

[repository.signing]
DEFAULT_TRUST_MODEL = committer

[oauth2]
JWT_SECRET = "{{ gitea_jwt_secret }}"

[oauth2_client]
# This allows Gitea to automatically create the account
# without the user filling out the registration form.
ENABLE_AUTO_REGISTRATION = true
